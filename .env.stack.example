# ---------------------------------------------------------------------------
# RSS + Clash 栈环境变量模板
# 使用前复制为 .env 或 .env.stack，填写实际值，勿提交含敏感信息的文件
# ---------------------------------------------------------------------------

# ---------- 构建/编排（脚本与 compose 使用） ----------
# RSSHub 子项目路径（用于 build rsshub 镜像）；默认 submodule ./RSSHub
RSSHUB_PATH=./RSSHub
# clash-aio 子项目路径（用于 build clash-with-ui）；默认 submodule ./clash-aio；也可改为 ../clash-aio 等
CLASH_AIO_PATH=./clash-aio
# 构建时代理（可选）：宿主机已开代理时设此项可加速 npm/pnpm 拉包；Windows/Mac 用 host.docker.internal
# BUILD_PROXY=http://host.docker.internal:7890

# ---------- Clash 代理（clash-with-ui 容器需要，与 clash-aio 的 .env 一致） ----------
# 原始订阅链接（必填）
RAW_SUB_URL=
# 宿主机代理端口（stack 内仅 rsshub 经内网访问 clash，可不映射；若需宿主机用代理则保留）
ALL_PROXY_PORT=7890
CONTROL_PANEL_PORT=9090

# ---------- RSSHub 代理（仅国外源走代理，国内直连） ----------
# 已在 docker-compose.stack.yml 中设为 PROXY_HOST=clash-with-ui PROXY_PORT=7890
# 重要：未设置 PROXY_URL_REGEX 时 RSSHub 默认 .*，即全部请求（含微博、B站）都走 Clash；
# 若 Clash 出口在海外，微博/B站易限流或 503。建议设置后仅国外站走代理：
PROXY_URL_REGEX=(youtube|twitter|telegram|github\.com|reddit)

# ---------- RSSHub 缓存（可选，降低请求频率、减少限流/封号风险） ----------
# CACHE_EXPIRE=600
# CACHE_CONTENT_EXPIRE=7200
# 说明：CACHE_EXPIRE 路由缓存秒数，默认 300；CACHE_CONTENT_EXPIRE 内容缓存秒数，默认 3600
# ---------- RSSHub 插件（可选；B 站 412 时可启用 filter 并使用 ?filterout=author） ----------
# RSSHUB_PLUGIN_FILTER=true

# ---------- 站点 Cookie（按需填写，提升抓取成功率与限流规避） ----------
# Bilibili：BILIBILI_COOKIE_<uid>= 从浏览器登录后复制的 Cookie 字符串（含 SESSDATA 等）
# 多账号可配置多条，如 BILIBILI_COOKIE_2267573=xxx
# 获取方式见 docs/bilibili-cookie-docker.md
# BILIBILI_COOKIE_<uid>=

# 微博：WEIBO_COOKIES= 从移动端/网页端提取的 Cookie
# WEIBO_COOKIES=

# ---------- 微博图片防盗链（可选；RSS 内图片/视频不显示时可配置） ----------
# 将微博描述中的图片 URL 重写为代理地址，绕过 sinaimg.cn 防盗链。视频仍可能需在浏览器中打开。
# 参考 https://docs.rsshub.app/zh/deploy/config#图片处理、https://github.com/DIYgod/RSSHub/issues/2769
# 注意：若通过 docker-compose 加载 .env，需写 $${href_ue}（双美元符）否则 compose 会替换掉变量
# HOTLINK_TEMPLATE=https://images.weserv.nl?url=$${href_ue}
# HOTLINK_INCLUDE_PATHS=/weibo

# 其他站点见 lib/config.js 或 RSSHub 文档，变量名一般为 *_COOKIE* / *_COOKIES
